{
  "info": {
    "name": "qoltanba REST API",
    "description": "Generated from the Go types (tools/openapigen). Set {{baseUrl}} and the base64/secret variables. All keys are lowerCamelCase.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "Signature",
      "item": [
        {
          "name": "Sign data (CMS / XML / WSSE)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"format\":\"cms\",\"data\":\"{{dataBase64}}\",\"key\":{\"path\":{\"path\":\"/keys/signer.p12\",\"password\":\"{{keyPassword}}\"}},\"detached\":false,\"withTimestamp\":false}"
            },
            "url": {
              "raw": "{{baseUrl}}/sign",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "sign"
              ]
            }
          }
        },
        {
          "name": "Co-sign — add a signer to an already-signed container",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"format\":\"cms\",\"data\":\"{{dataBase64}}\",\"key\":{\"path\":{\"path\":\"/keys/signer2.p12\",\"password\":\"{{keyPassword}}\"}},\"existingSignature\":\"{{signatureBase64}}\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/sign/add",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "sign",
                "add"
              ]
            }
          }
        },
        {
          "name": "Verify a signature and extract everything available",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"format\":\"cms\",\"signature\":\"{{signatureBase64}}\",\"checkCertTime\":true,\"extractContent\":true,\"claims\":true}"
            },
            "url": {
              "raw": "{{baseUrl}}/verify",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "verify"
              ]
            }
          }
        },
        {
          "name": "Recover the original content from an attached signature",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"format\":\"cms\",\"signature\":\"{{signatureBase64}}\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/extract",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "extract"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Certificate",
      "item": [
        {
          "name": "Fully parse a certificate (optionally build/validate the chain, add claims)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"cert\":\"{{certBase64}}\",\"encoding\":\"der\",\"buildChain\":true,\"claims\":true}"
            },
            "url": {
              "raw": "{{baseUrl}}/cert/info",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cert",
                "info"
              ]
            }
          }
        },
        {
          "name": "Check a certificate's revocation status (OCSP / CRL)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"cert\":\"{{certBase64}}\",\"encoding\":\"der\",\"method\":\"ocsp\",\"wantOcsp\":true}"
            },
            "url": {
              "raw": "{{baseUrl}}/cert/validate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cert",
                "validate"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Batch",
      "item": [
        {
          "name": "Sign many items (aggregated JSON, or NDJSON stream with Accept: application/x-ndjson)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"items\":[{\"format\":\"cms\",\"data\":\"{{dataBase64}}\",\"key\":{\"path\":{\"path\":\"/keys/signer.p12\",\"password\":\"{{keyPassword}}\"}}}],\"policy\":\"continue-on-error\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/sign/batch",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "sign",
                "batch"
              ]
            }
          }
        },
        {
          "name": "Verify many signatures",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"items\":[{\"format\":\"cms\",\"signature\":\"{{signatureBase64}}\"}],\"policy\":\"continue-on-error\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/verify/batch",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "verify",
                "batch"
              ]
            }
          }
        },
        {
          "name": "Recover content from many attached signatures",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"items\":[{\"format\":\"cms\",\"signature\":\"{{signatureBase64}}\"}]}"
            },
            "url": {
              "raw": "{{baseUrl}}/extract/batch",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "extract",
                "batch"
              ]
            }
          }
        },
        {
          "name": "Parse many certificates",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"items\":[{\"cert\":\"{{certBase64}}\",\"encoding\":\"der\"}]}"
            },
            "url": {
              "raw": "{{baseUrl}}/cert/info/batch",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cert",
                "info",
                "batch"
              ]
            }
          }
        },
        {
          "name": "Check revocation for many certificates",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"items\":[{\"cert\":\"{{certBase64}}\",\"encoding\":\"der\",\"method\":\"ocsp\"}]}"
            },
            "url": {
              "raw": "{{baseUrl}}/cert/validate/batch",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cert",
                "validate",
                "batch"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Oidc",
      "item": [
        {
          "name": "OpenID Connect discovery document",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/.well-known/openid-configuration",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                ".well-known",
                "openid-configuration"
              ]
            }
          }
        },
        {
          "name": "JSON Web Key Set for token verification",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/oidc/jwks.json",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "oidc",
                "jwks.json"
              ]
            }
          }
        },
        {
          "name": "Issue a challenge nonce to sign with ЭЦП",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"nonce\":\"{{rpNonce}}\",\"state\":\"{{rpState}}\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/oidc/challenge",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "oidc",
                "challenge"
              ]
            }
          }
        },
        {
          "name": "Verify the signed challenge and issue OIDC tokens",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"challengeId\":\"{{challengeId}}\",\"signature\":\"{{signatureBase64}}\",\"clientId\":\"{{clientId}}\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/oidc/verify",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "oidc",
                "verify"
              ]
            }
          }
        },
        {
          "name": "Claims for a bearer access token",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/oidc/userinfo",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "oidc",
                "userinfo"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Qr",
      "item": [
        {
          "name": "Start an eGov Mobile QR signing/auth session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"mode\":\"sign\",\"profile\":\"agnostic\",\"data\":\"{{dataBase64}}\",\"callbackUrl\":\"{{callbackUrl}}\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/qr/sessions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "qr",
                "sessions"
              ]
            }
          }
        },
        {
          "name": "Poll a QR session for the verified result or tokens",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/qr/sessions/{id}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "qr",
                "sessions",
                "{id}"
              ]
            }
          }
        },
        {
          "name": "App-facing: eGov Mobile fetches the data-to-sign",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/qr/a/{id}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "qr",
                "a",
                "{id}"
              ]
            }
          }
        },
        {
          "name": "App-facing: eGov Mobile returns the signature",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"signature\":\"{{signatureBase64}}\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/qr/a/{id}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "qr",
                "a",
                "{id}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Observability",
      "item": [
        {
          "name": "Liveness — the process is up",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/healthz",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "healthz"
              ]
            }
          }
        },
        {
          "name": "Readiness — library loaded and self-tested",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/readyz",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "readyz"
              ]
            }
          }
        },
        {
          "name": "Non-sensitive service status (no secrets)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/statusz",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "statusz"
              ]
            }
          }
        },
        {
          "name": "Prometheus metrics",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/metrics",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "metrics"
              ]
            }
          }
        }
      ]
    }
  ]
}
