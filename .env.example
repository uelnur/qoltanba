# qoltanba — example environment configuration.
#
# Every setting has three surfaces derived from one registry entry: a flag
# (--log-level), an env var (QOLTANBA_LOG_LEVEL) and a config-file key (log.level).
# Precedence (low → high): defaults < config file < env < flags.
# Secrets are read only from env or a *_FILE side-file, never from flags.
#
# Copy to .env and adjust. Inspect the resolved config with:
#   qoltanba config-dump
#
# ── Native library (BYOL: you supply the Kalkan library; it is never bundled) ──
QOLTANBA_LIB_PATH=/opt/kalkan/libkalkancryptwr-64.so
#QOLTANBA_LIB_VERSION=            # override version detection (else from file name)
#QOLTANBA_LIB_ISOLATED=false      # isolate pool instances (dlmopen; Linux, workers>1)
#QOLTANBA_LIB_ISOLATION_DEPS=     # comma-separated namespace deps for isolation

# ── Workers / mode ──
QOLTANBA_WORKERS=1                 # max parallel crypto ops; >1 requires LIB_ISOLATED=true
#QOLTANBA_VERIFY_ONLY=false        # disable the key path and sign endpoints entirely

# ── REST transport ──
QOLTANBA_HTTP_ENABLED=true
QOLTANBA_HTTP_ADDR=:8080           # ":port" for TCP, or "unix:/run/kalkan.sock"

# ── gRPC transport ──
#QOLTANBA_GRPC_ENABLED=false
#QOLTANBA_GRPC_ADDR=:9091          # ":port" for TCP, or "unix:/run/kalkan-grpc.sock"

# ── RabbitMQ transport (enabled by setting the URL) ──
#QOLTANBA_AMQP_URL=amqp://guest:guest@localhost:5672/   # secret; queue provisioned by you
#QOLTANBA_AMQP_QUEUE=kalkan.requests                    # request queue to consume
#QOLTANBA_AMQP_REPLY_QUEUE=                             # fixed reply queue (empty → per-message reply-to)
#QOLTANBA_AMQP_PREFETCH=0                               # QoS prefetch (0 → worker count)

# ── Kafka transport (enabled by setting brokers) ──
#QOLTANBA_KAFKA_BROKERS=localhost:9092                  # comma-separated seed brokers
#QOLTANBA_KAFKA_TOPIC=kalkan.requests                   # request topic
#QOLTANBA_KAFKA_REPLY_TOPIC=kalkan.replies              # default reply topic (reply-topic header overrides)
#QOLTANBA_KAFKA_GROUP=qoltanba                    # consumer group id

# ── NATS JetStream transport (enabled by setting the URL) ──
#QOLTANBA_NATS_URL=nats://localhost:4222                # secret; stream provisioned by you
#QOLTANBA_NATS_SUBJECT=kalkan.requests                  # request subject
#QOLTANBA_NATS_QUEUE=                                   # queue group for load balancing (optional)
#QOLTANBA_NATS_REPLY_SUBJECT=                           # fallback reply subject (empty → per-message reply-to)
#QOLTANBA_NATS_DURABLE=qoltanba                   # durable consumer name

# ── Chain building ──
#QOLTANBA_TRUST_FETCH_AIA=false       # download missing issuers via AIA (CA Issuers URL, incl. .p7c)
#QOLTANBA_TRUST_AIA_TIMEOUT=5         # AIA/registry fetch timeout, seconds
#QOLTANBA_TRUST_USE_RK_REGISTRY=false # preload anchors from the official RK CA registry
#QOLTANBA_TRUST_RK_INCLUDE_TEST=false # include RK test roots when preloading
#QOLTANBA_TRUST_VERIFY_CHAIN=false    # cryptographically validate the signer chain via Kalkan (incl. GOST)
#QOLTANBA_TRUST_REFRESH_INTERVAL=     # background anchor-refresh cadence (e.g. 24h); empty=auto (24h with RK registry), 0/off=disabled
#QOLTANBA_TRUST_CRL_CACHE=false       # cache CRLs by distribution point for Method=CRL validation without inline CRL

# ── Keys / trust ──
#QOLTANBA_KEYS_ALLOW_INLINE=false  # accept inline PKCS#12 in requests (TLS/local only)
#QOLTANBA_SIGN_DEFAULT_TIMESTAMP=false # add a TSA timestamp by default (request may override per call)
#QOLTANBA_TRUST_CA_DIR=/etc/qoltanba/ca   # dir of trusted CA PEM files

# ── Observability ──
QOLTANBA_LOG_LEVEL=info            # debug|info|warn|error
QOLTANBA_LOG_FORMAT=text           # text|json (json for ELK/Loki)
#QOLTANBA_METRICS_ENABLED=false   # expose health/status + Prometheus /metrics on a separate port (also works in gRPC/MQ-only mode)
#QOLTANBA_METRICS_ADDR=:9090      # separate observability port; /metrics is also served on the work port when HTTP is enabled

# ── Secrets via side-files (Docker/K8s secrets, systemd LoadCredential) ──
# For any QOLTANBA_<KEY>, a QOLTANBA_<KEY>_FILE points at a file whose contents
# become the value. Example (illustrative — inline key passwords arrive per
# request, not via config):
#QOLTANBA_SOME_SECRET_FILE=/run/secrets/some_secret

# ── Config file (optional; env/flags still override it) ──
#QOLTANBA_CONFIG=/etc/qoltanba/config.yaml
