# EnvironmentFile for the systemd unit. Non-secret settings only.
# Secrets go through systemd LoadCredential + QOLTANBA_<KEY>_FILE (see the unit).
# These override the config file; flags on ExecStart override these.

QOLTANBA_LIB_PATH=/opt/kalkan/libkalkancryptwr-64.so
QOLTANBA_HTTP_ADDR=:8080
QOLTANBA_LOG_LEVEL=info
QOLTANBA_LOG_FORMAT=json
# Loader wiring for the OpenSSL-1.1 fork / iconv from the BYOL bundle.
LD_LIBRARY_PATH=/opt/kalkan
